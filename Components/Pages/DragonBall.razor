@page "/dragon-ball"

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dragon Ball Z — Estante Azul</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header class="topbar">
        <a href="/" class="back-link">← Voltar para a Home</a>
    </header>

    <main class="detail-wrapper">

        <h2 class="group-title">Detalhes do Livro</h2>

        <div class="detail-card">

            <div class="detail-cover cover--f">
                <span class="letter">悟</span>
            </div>

            <div class="detail-info">
                <span class="badge-genre">Ação · Aventura · Mangá</span>
                <h1>Dragon Ball Z</h1>
                <p class="author">Akira Toriyama</p>

                <p class="synopsis">
                    A continuação acompanha Goku, agora adulto, enfrentando ameaças cada vez mais
                    poderosas ao lado de seus amigos e familiares. Entre treinos intensos e batalhas
                    épicas contra guerreiros de outros planetas, a obra explora temas de superação,
                    amizade e sacrifício em defesa da Terra.
                </p>

                <div class="detail-meta">
                    <span><strong>Volumes:</strong> 26</span>
                    <span><strong>Status:</strong> <span class="ok">Disponível</span></span>
                </div>
            </div>

        </div>

    </main>

</body>
</html>
