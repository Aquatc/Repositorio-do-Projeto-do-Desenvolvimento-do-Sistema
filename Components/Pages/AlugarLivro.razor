@page "/alugarLivro"

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alugar Livro</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <main class="container">

        <h2 class="group-title">Alugar Livro</h2>

        <form class="rent-card" onsubmit="return false;">

            <div class="field">
                <label for="livro">Livro</label>
                <select id="livro" name="livro">
                    <option value="">Selecione um livro</option>
                    <option value="capitaes">Capitães da Areia — Jorge Amado</option>
                    <option value="revolucao">A Revolução dos Bichos — George Orwell</option>
                    <option value="domcasmurro">Dom Casmurro — Machado de Assis</option>
                    <option value="vidassecas">Vidas Secas — Graciliano Ramos</option>
                    <option value="bisquedoll">Sono Bisque Doll wa Koi wo Suru — Shinichi Fukuda</option>
                    <option value="apotecaria">Diários de uma Apotecária — Natsu Hyuuga</option>
                    <option value="tengoku">Tengoku Daimakyou — Masakazu Ishiguro</option>
                    <option value="dragonball">Dragon Ball Z — Akira Toriyama</option>
                </select>
            </div>

            <div class="field-row">
                <div class="field">
                    <label for="nome">Nome do leitor</label>
                    <input type="text" id="nome" name="nome" placeholder="Digite seu nome completo">
                </div>

                <div class="field">
                    <label for="matricula">Matrícula</label>
                    <input type="text" id="matricula" name="matricula" placeholder="Nº de matrícula">
                </div>
            </div>

            <div class="field-row">
                <div class="field">
                    <label for="retirada">Data de retirada</label>
                    <input type="date" id="retirada" name="retirada">
                </div>

                <div class="field">
                    <label for="devolucao">Data de devolução</label>
                    <input type="date" id="devolucao" name="devolucao">
                </div>
            </div>

            <div class="field">
                <label for="obs">Observações</label>
                <textarea id="obs" name="obs" rows="3" placeholder="Alguma observação sobre o empréstimo (opcional)"></textarea>
            </div>

            <div class="status-preview">
                <span class="ok">Disponível para retirada</span>
            </div>

            <button type="submit" class="btn-confirm">Confirmar Aluguel</button>

        </form>

    </main>

</body>
</html>

