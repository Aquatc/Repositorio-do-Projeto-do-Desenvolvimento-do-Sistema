@page "/apotecaria"

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Diários de uma Apotecária — Estante Azul</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header class="topbar">
        <a href="/" class="back-link">← Voltar para a Home</a>
    </header>

    <main class="detail-wrapper">

        <h2 class="group-title">Detalhes do Livro</h2>

        <div class="detail-card">

            <div class="detail-cover cover--d">
                <span class="letter">薬</span>
            </div>

            <div class="detail-info">
                <span class="badge-genre">Mistério histórico · Mangá</span>
                <h1>Diários de uma Apotecária</h1>
                <p class="author">Natsu Hyuuga</p>

                <p class="synopsis">
                    Ambientada em uma corte antiga inspirada na China imperial, a história segue uma
                    jovem farmacêutica com grande conhecimento de ervas medicinais que passa a
                    trabalhar no palácio. Usando sua inteligência e seu olhar clínico, ela acaba se
                    envolvendo na resolução de mistérios e intrigas dentro da corte.
                </p>

                <div class="detail-meta">
                    <span><strong>Volumes:</strong> Em publicação</span>
                    <span><strong>Status:</strong> <span class="ok">Disponível</span></span>
                </div>
            </div>

        </div>

    </main>

</body>
</html>

