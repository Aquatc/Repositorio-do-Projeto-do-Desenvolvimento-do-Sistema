@page "/tengoku-daimakyou"

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tengoku Daimakyou — Estante Azul</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header class="topbar">
        <a href="/" class="back-link">← Voltar para a Home</a>
    </header>

    <main class="detail-wrapper">

        <h2 class="group-title">Detalhes do Livro</h2>

        <div class="detail-card">

            <div class="detail-cover cover--e">
                <span class="letter">天</span>
            </div>

            <div class="detail-info">
                <span class="badge-genre">Ficção científica · Mangá</span>
                <h1>Tengoku Daimakyou</h1>
                <p class="author">Masakazu Ishiguro</p>

                <p class="synopsis">
                    A trama se divide em duas linhas paralelas: um grupo de jovens explorando um
                    mundo devastado e perigoso fora dos muros de sua vila, e crianças crescendo
                    isoladas dentro de uma instalação que parece esconder segredos sobre o real
                    estado do mundo. Aos poucos, as duas histórias começam a se conectar.
                </p>

                <div class="detail-meta">
                    <span><strong>Volumes:</strong> Em publicação</span>
                    <span><strong>Status:</strong> <span class="ok">Disponível</span></span>
                </div>
            </div>

        </div>

    </main>

</body>
</html>

