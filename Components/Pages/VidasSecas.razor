@page "/vidas-secas"

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vidas Secas — Estante Azul</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header class="topbar">
        <a href="/" class="back-link">← Voltar para a Home</a>
    </header>

    <main class="detail-wrapper">

        <h2 class="group-title">Detalhes do Livro</h2>

        <div class="detail-card">

            <div class="detail-cover cover--h">
                <span class="letter">V</span>
            </div>

            <div class="detail-info">
                <span class="badge-genre">Romance · Literatura brasileira</span>
                <h1>Vidas Secas</h1>
                <p class="author">Graciliano Ramos</p>

                <p class="synopsis">
                    A obra acompanha uma família de retirantes que atravessa o sertão nordestino
                    fugindo da seca, em busca de um lugar onde possam sobreviver. Com uma linguagem
                    seca e direta, o livro retrata a dureza da vida no campo e a luta constante
                    contra a fome e o abandono.
                </p>

                <div class="detail-meta">
                    <span><strong>Páginas:</strong> 176</span>
                    <span><strong>Status:</strong> <span class="ok">Disponível</span></span>
                </div>
            </div>

        </div>

    </main>

</body>
</html>
