@page "/login"

<div class="login-box">

    <label>Email</label>
    <input type="email" placeholder="Seu@gmail.com">

    <label>Senha</label>
    <input type="password" placeholder="Senha">


    <button class="solid">
        Entrar
    </button>

    <button class="outline">
        Registrar
    </button>

    <button class="clear">
        Recuperar senha
    </button>

</div>