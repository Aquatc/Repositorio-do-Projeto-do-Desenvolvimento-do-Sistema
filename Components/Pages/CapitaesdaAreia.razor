@page "/capitaes-da-areia"

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Capitães da Areia — Estante Azul</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header class="topbar">
        <a href="/" class="back-link">← Voltar para a Home</a>
    </header>

    <main class="detail-wrapper">

        <h2 class="group-title">Detalhes do Livro</h2>

        <div class="detail-card">

            <div class="detail-cover cover--a">
                <span class="letter">C</span>
            </div>

            <div class="detail-info">
                <span class="badge-genre">Romance · Drama social</span>
                <h1>Capitães da Areia</h1>
                <p class="author">Jorge Amado</p>

                <p class="synopsis">
                    A história acompanha um grupo de meninos abandonados que vivem nas ruas de Salvador,
                    sobrevivendo por conta própria em meio à pobreza e à desigualdade social.
                    Entre pequenos furtos e uma forte lealdade entre si, o grupo forma uma espécie de
                    família alternativa, enquanto cada personagem lida à sua maneira com os sonhos e
                    as dificuldades de crescer à margem da sociedade.
                </p>

                <div class="detail-meta">
                    <span><strong>Páginas:</strong> 280</span>
                    <span><strong>Status:</strong> <span class="ok">Disponível</span></span>
                </div>
            </div>

        </div>

    </main>

</body>
</html>
