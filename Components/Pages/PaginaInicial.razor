@page "/paginaInicial"
@page "/"

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estante Azul — Biblioteca</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header class="topbar">
        <form class="searchbar" onsubmit="return false;">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
                <line x1="16.5" y1="16.5" x2="21" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
            <input type="text" placeholder="Buscar título ou autor...">
        </form>

        <div class="topbar-actions">
            <a href="/alugarLivro" class="btn-rent">Alugar Livro</a>
            <a href="/devolverLivro" class="btn-return">Devolver Livro</a>
        </div>
    </header>

    <main class="container">

        <h2 class="group-title">Livros</h2>
        <div class="grid">

            <a href="/capitaes-da-areia" class="book">
                <div class="cover cover--a">
                    <span class="letter">C</span>
                </div>
                <h3>Capitães da Areia</h3>
                <p class="sub">Jorge Amado</p>
                <p class="stat"><span class="ok">Disponível</span></p>
            </a>

            <a href="/revolucao-dos-bichos" class="book">
                <div class="cover cover--b">
                    <span class="letter">R</span>
                </div>
                <h3>A Revolução dos Bichos</h3>
                <p class="sub">George Orwell</p>
                <p class="stat"><span class="ok">Disponível</span></p>
            </a>

            <a href="/dom-casmurro" class="book">
                <div class="cover cover--g">
                    <span class="letter">D</span>
                </div>
                <h3>Dom Casmurro</h3>
                <p class="sub">Machado de Assis</p>
                <p class="stat"><span class="ok">Disponível</span></p>
            </a>

            <a href="/vidas-secas" class="book">
                <div class="cover cover--h">
                    <span class="letter">V</span>
                </div>
                <h3>Vidas Secas</h3>
                <p class="sub">Graciliano Ramos</p>
                <p class="stat"><span class="ok">Disponível</span></p>
            </a>

        </div>

        <h2 class="group-title">Mangás</h2>
        <div class="grid">

            <a href="/sono-bisque" class="book">
                <div class="cover cover--c">
                    <span class="letter">祐</span>
                </div>
                <h3>Sono Bisque Doll wa Koi wo Suru</h3>
                <p class="sub">Shinichi Fukuda</p>
                <p class="stat"><span class="ok">Disponível</span></p>
            </a>

            <a href="/apotecaria" class="book">
                <div class="cover cover--d">
                    <span class="letter">薬</span>
                </div>
                <h3>Diários de uma Apotecária</h3>
                <p class="sub">Natsu Hyuuga</p>
                <p class="stat"><span class="ok">Disponível</span></p>
            </a>

            <a href="/tengoku-daimakyou" class="book">
                <div class="cover cover--e">
                    <span class="letter">天</span>
                </div>
                <h3>Tengoku Daimakyou</h3>
                <p class="sub">Masakazu Ishiguro</p>
                <p class="stat"><span class="ok">Disponível</span></p>
            </a>

            <a href="/dragon-ball" class="book">
                <div class="cover cover--f">
                    <span class="letter">悟</span>
                </div>
                <h3>Dragon Ball Z</h3>
                <p class="sub">Akira Toriyama</p>
                <p class="stat"><span class="ok">Disponível</span></p>
            </a>

        </div>

    </main>

</body>
</html>

