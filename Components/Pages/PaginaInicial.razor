<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Biblioteca Aracê — Início</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header class="topbar">
        <div class="topbar__inner">
            <a href="#topo" class="marca">
                <span class="marca__selo">B·A</span>
                <span class="marca__texto">Biblioteca<br>Aracê</span>
            </a>

            <nav class="nav">
                <a href="#acervo">Acervo</a>
                <a href="#mangas">Mangás</a>
                <a href="#horarios">Horários</a>
                <a href="#contato">Contato</a>
            </nav>

            <form class="busca" role="search">
                <input type="search" placeholder="Buscar por título, autor..." aria-label="Buscar no acervo">
                <button type="submit" aria-label="Buscar">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="7" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                </button>
            </form>
        </div>
    </header>

    <main id="topo">

        <section class="hero">
            <div class="hero__texto">
                <p class="hero__eyebrow">Catálogo aberto ao público</p>
                <h1>Toda leitura<br>começa com uma<br><em>ficha em branco.</em></h1>
                <p class="hero__desc">Consulte o acervo, reserve um exemplar e retire na sua unidade mais próxima. Literatura nacional, clássicos e mangás — tudo no mesmo catálogo.</p>
                <div class="hero__acoes">
                    <a href="#acervo" class="botao botao--cheio">Ver acervo</a>
                    <a href="#mangas" class="botao botao--linha">Ver mangás</a>
                </div>
            </div>

            <div class="hero__cartao" aria-hidden="true">
                <div class="cartao-emprestimo">
                    <div class="cartao-emprestimo__topo">
                        <span>FICHA DE EMPRÉSTIMO</span>
                        <span class="cartao-emprestimo__num">Nº 0192</span>
                    </div>
                    <div class="cartao-emprestimo__linha">
                        <span class="rotulo">Título</span>
                        <span class="valor">Capitães da Areia</span>
                    </div>
                    <div class="cartao-emprestimo__linha">
                        <span class="rotulo">Leitor</span>
                        <span class="valor">___________________</span>
                    </div>
                    <div class="cartao-emprestimo__linha">
                        <span class="rotulo">Devolução</span>
                        <span class="valor">___/___/______</span>
                    </div>
                    <div class="carimbo">EMPRESTADO</div>
                </div>
            </div>
        </section>

        <section class="acervo" id="acervo">
            <div class="secao__cabecalho">
                <p class="secao__eyebrow">Estante 01</p>
                <h2>Literatura</h2>
            </div>

            <div class="grade-livros">

                <article class="livro">
                    <div class="livro__capa livro__capa--1">
                        <span class="livro__capa-titulo">Capitães<br>da Areia</span>
                    </div>
                    <div class="ficha">CDD 869.3</div>
                    <h3>Capitães da Areia</h3>
                    <p class="autor">Jorge Amado</p>
                    <span class="etiqueta etiqueta--disponivel">Disponível</span>
                </article>

                <article class="livro">
                    <div class="livro__capa livro__capa--2">
                        <span class="livro__capa-titulo">Dom<br>Casmurro</span>
                    </div>
                    <div class="ficha">CDD 869.3</div>
                    <h3>Dom Casmurro</h3>
                    <p class="autor">Machado de Assis</p>
                    <span class="etiqueta etiqueta--disponivel">Disponível</span>
                </article>

                <article class="livro">
                    <div class="livro__capa livro__capa--3">
                        <span class="livro__capa-titulo">O<br>Cortiço</span>
                    </div>
                    <div class="ficha">CDD 869.3</div>
                    <h3>O Cortiço</h3>
                    <p class="autor">Aluísio Azevedo</p>
                    <span class="etiqueta etiqueta--emprestado">Emprestado</span>
                </article>

                <article class="livro">
                    <div class="livro__capa livro__capa--4">
                        <span class="livro__capa-titulo">Memórias<br>Póstumas</span>
                    </div>
                    <div class="ficha">CDD 869.3</div>
                    <h3>Memórias Póstumas de Brás Cubas</h3>
                    <p class="autor">Machado de Assis</p>
                    <span class="etiqueta etiqueta--disponivel">Disponível</span>
                </article>

            </div>
        </section>

        <section class="acervo acervo--mangas" id="mangas">
            <div class="secao__cabecalho">
                <p class="secao__eyebrow">Estante 02</p>
                <h2>Mangás</h2>
            </div>

            <div class="grade-livros">

                <article class="livro">
                    <div class="livro__capa livro__capa--5">
                        <span class="livro__capa-titulo">Sono<br>Bisque<br>Doll</span>
                    </div>
                    <div class="ficha">MNG vol. 01</div>
                    <h3>Sono Bisque Doll wa Koi wo Suru</h3>
                    <p class="autor">Shinichi Fukuda</p>
                    <span class="etiqueta etiqueta--disponivel">Disponível</span>
                </article>

                <article class="livro">
                    <div class="livro__capa livro__capa--6">
                        <span class="livro__capa-titulo">Diários de<br>uma<br>Apotecária</span>
                    </div>
                    <div class="ficha">MNG vol. 01</div>
                    <h3>Diários de uma Apotecária</h3>
                    <p class="autor">Natsu Hyuuga · Nekokurage</p>
                    <span class="etiqueta etiqueta--disponivel">Disponível</span>
                </article>

                <article class="livro">
                    <div class="livro__capa livro__capa--7">
                        <span class="livro__capa-titulo">Ilusão<br>Celestial</span>
                    </div>
                    <div class="ficha">MNG vol. 01</div>
                    <h3>Ilusão Celestial</h3>
                    <p class="autor">Acervo de mangás</p>
                    <span class="etiqueta etiqueta--emprestado">Emprestado</span>
                </article>

                <article class="livro">
                    <div class="livro__capa livro__capa--8">
                        <span class="livro__capa-titulo">Dragon<br>Ball Z</span>
                    </div>
                    <div class="ficha">MNG vol. 01</div>
                    <h3>Dragon Ball Z</h3>
                    <p class="autor">Akira Toriyama</p>
                    <span class="etiqueta etiqueta--disponivel">Disponível</span>
                </article>

            </div>
        </section>

        <section class="horarios" id="horarios">
            <div class="horarios__cartao">
                <h2>Horário de funcionamento</h2>
                <ul>
                    <li><span>Segunda a sexta</span><span>08h — 20h</span></li>
                    <li><span>Sábado</span><span>08h — 13h</span></li>
                    <li><span>Domingo e feriados</span><span>Fechado</span></li>
                </ul>
            </div>
            <div class="horarios__cartao horarios__cartao--escuro">
                <h2>Como emprestar</h2>
                <ol>
                    <li>Consulte a disponibilidade no catálogo.</li>
                    <li>Reserve o exemplar pelo balcão ou pelo site.</li>
                    <li>Retire com sua carteirinha em até 48h.</li>
                </ol>
            </div>
        </section>

    </main>

    <footer class="rodape" id="contato">
        <div class="rodape__inner">
            <div class="marca marca--rodape">
                <span class="marca__selo">B·A</span>
                <span class="marca__texto">Biblioteca<br>Aracê</span>
            </div>
            <p>Rua das Letras, 120 — Centro</p>
            <p>(69) 0000-0000 · contato@bibliotecaarace.exemplo</p>
            <p class="rodape__linha">© 2026 Biblioteca Aracê. Catálogo de exemplo.</p>
        </div>
    </footer>

</body>
</html>