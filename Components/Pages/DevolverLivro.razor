@page "/devolverLivro"

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Devolver Livro — Estante Azul</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header class="topbar">
        <a href="/" class="back-link">← Voltar para a Home</a>
    </header>

    <main class="detail-wrapper">

        <h2 class="group-title">Selecione o livro que vai devolver</h2>

        <div class="return-page">

            <input type="radio" id="r-capitaes" name="livro-devolver" class="book-radio">
            <input type="radio" id="r-revolucao" name="livro-devolver" class="book-radio">
            <input type="radio" id="r-domcasmurro" name="livro-devolver" class="book-radio">
            <input type="radio" id="r-vidassecas" name="livro-devolver" class="book-radio">
            <input type="radio" id="r-bisquedoll" name="livro-devolver" class="book-radio">
            <input type="radio" id="r-apotecaria" name="livro-devolver" class="book-radio">
            <input type="radio" id="r-tengoku" name="livro-devolver" class="book-radio">
            <input type="radio" id="r-dragonball" name="livro-devolver" class="book-radio">

            <div class="grid">

                <label for="r-capitaes" class="book">
                    <div class="cover cover--a"><span class="letter">C</span></div>
                    <h3>Capitães da Areia</h3>
                    <p class="sub">Jorge Amado</p>
                </label>

                <label for="r-revolucao" class="book">
                    <div class="cover cover--b"><span class="letter">R</span></div>
                    <h3>A Revolução dos Bichos</h3>
                    <p class="sub">George Orwell</p>
                </label>

                <label for="r-domcasmurro" class="book">
                    <div class="cover cover--g"><span class="letter">D</span></div>
                    <h3>Dom Casmurro</h3>
                    <p class="sub">Machado de Assis</p>
                </label>

                <label for="r-vidassecas" class="book">
                    <div class="cover cover--h"><span class="letter">V</span></div>
                    <h3>Vidas Secas</h3>
                    <p class="sub">Graciliano Ramos</p>
                </label>

                <label for="r-bisquedoll" class="book">
                    <div class="cover cover--c"><span class="letter">祐</span></div>
                    <h3>Sono Bisque Doll wa Koi wo Suru</h3>
                    <p class="sub">Shinichi Fukuda</p>
                </label>

                <label for="r-apotecaria" class="book">
                    <div class="cover cover--d"><span class="letter">薬</span></div>
                    <h3>Diários de uma Apotecária</h3>
                    <p class="sub">Natsu Hyuuga</p>
                </label>

                <label for="r-tengoku" class="book">
                    <div class="cover cover--e"><span class="letter">天</span></div>
                    <h3>Tengoku Daimakyou</h3>
                    <p class="sub">Masakazu Ishiguro</p>
                </label>

                <label for="r-dragonball" class="book">
                    <div class="cover cover--f"><span class="letter">悟</span></div>
                    <h3>Dragon Ball Z</h3>
                    <p class="sub">Akira Toriyama</p>
                </label>

            </div>

            <div class="result">

                <div class="detail-card" id="card-capitaes">
                    <div class="detail-cover cover--a"><span class="letter">C</span></div>
                    <div class="detail-info">
                        <span class="badge-genre">Empréstimo #0221</span>
                        <h1>Capitães da Areia</h1>
                        <p class="author">Jorge Amado · Leitor: Elizeu</p>
                        <div class="loan-dates">
                            <div class="date-item"><span class="date-label">Retirado em</span><span class="date-value">03/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Prazo</span><span class="date-value">17/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Hoje</span><span class="date-value">21/07/2026</span></div>
                        </div>
                        <div class="detail-meta"><span class="late">Atrasado · 4 dias</span></div>
                        <button type="button" class="btn-confirm">Confirmar Devolução</button>
                    </div>
                </div>

                <div class="detail-card" id="card-revolucao">
                    <div class="detail-cover cover--b"><span class="letter">R</span></div>
                    <div class="detail-info">
                        <span class="badge-genre">Empréstimo #0222</span>
                        <h1>A Revolução dos Bichos</h1>
                        <p class="author">George Orwell · Leitor: Elizeu</p>
                        <div class="loan-dates">
                            <div class="date-item"><span class="date-label">Retirado em</span><span class="date-value">10/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Prazo</span><span class="date-value">24/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Hoje</span><span class="date-value">21/07/2026</span></div>
                        </div>
                        <div class="detail-meta"><span class="ok">No prazo · 3 dias restantes</span></div>
                        <button type="button" class="btn-confirm">Confirmar Devolução</button>
                    </div>
                </div>

                <div class="detail-card" id="card-domcasmurro">
                    <div class="detail-cover cover--g"><span class="letter">D</span></div>
                    <div class="detail-info">
                        <span class="badge-genre">Empréstimo #0223</span>
                        <h1>Dom Casmurro</h1>
                        <p class="author">Machado de Assis · Leitor: Elizeu</p>
                        <div class="loan-dates">
                            <div class="date-item"><span class="date-label">Retirado em</span><span class="date-value">14/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Prazo</span><span class="date-value">28/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Hoje</span><span class="date-value">21/07/2026</span></div>
                        </div>
                        <div class="detail-meta"><span class="ok">No prazo · 7 dias restantes</span></div>
                        <button type="button" class="btn-confirm">Confirmar Devolução</button>
                    </div>
                </div>

                <div class="detail-card" id="card-vidassecas">
                    <div class="detail-cover cover--h"><span class="letter">V</span></div>
                    <div class="detail-info">
                        <span class="badge-genre">Empréstimo #0224</span>
                        <h1>Vidas Secas</h1>
                        <p class="author">Graciliano Ramos · Leitor: Elizeu</p>
                        <div class="loan-dates">
                            <div class="date-item"><span class="date-label">Retirado em</span><span class="date-value">01/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Prazo</span><span class="date-value">15/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Hoje</span><span class="date-value">21/07/2026</span></div>
                        </div>
                        <div class="detail-meta"><span class="late">Atrasado · 6 dias</span></div>
                        <button type="button" class="btn-confirm">Confirmar Devolução</button>
                    </div>
                </div>

                <div class="detail-card" id="card-bisquedoll">
                    <div class="detail-cover cover--c"><span class="letter">祐</span></div>
                    <div class="detail-info">
                        <span class="badge-genre">Empréstimo #0225</span>
                        <h1>Sono Bisque Doll wa Koi wo Suru</h1>
                        <p class="author">Shinichi Fukuda · Leitor: Elizeu</p>
                        <div class="loan-dates">
                            <div class="date-item"><span class="date-label">Retirado em</span><span class="date-value">16/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Prazo</span><span class="date-value">30/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Hoje</span><span class="date-value">21/07/2026</span></div>
                        </div>
                        <div class="detail-meta"><span class="ok">No prazo · 9 dias restantes</span></div>
                        <button type="button" class="btn-confirm">Confirmar Devolução</button>
                    </div>
                </div>

                <div class="detail-card" id="card-apotecaria">
                    <div class="detail-cover cover--d"><span class="letter">薬</span></div>
                    <div class="detail-info">
                        <span class="badge-genre">Empréstimo #0226</span>
                        <h1>Diários de uma Apotecária</h1>
                        <p class="author">Natsu Hyuuga · Leitor: Elizeu</p>
                        <div class="loan-dates">
                            <div class="date-item"><span class="date-label">Retirado em</span><span class="date-value">05/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Prazo</span><span class="date-value">18/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Hoje</span><span class="date-value">21/07/2026</span></div>
                        </div>
                        <div class="detail-meta"><span class="late">Atrasado · 3 dias</span></div>
                        <button type="button" class="btn-confirm">Confirmar Devolução</button>
                    </div>
                </div>

                <div class="detail-card" id="card-tengoku">
                    <div class="detail-cover cover--e"><span class="letter">天</span></div>
                    <div class="detail-info">
                        <span class="badge-genre">Empréstimo #0227</span>
                        <h1>Tengoku Daimakyou</h1>
                        <p class="author">Masakazu Ishiguro · Leitor: Elizeu</p>
                        <div class="loan-dates">
                            <div class="date-item"><span class="date-label">Retirado em</span><span class="date-value">12/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Prazo</span><span class="date-value">26/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Hoje</span><span class="date-value">21/07/2026</span></div>
                        </div>
                        <div class="detail-meta"><span class="ok">No prazo · 5 dias restantes</span></div>
                        <button type="button" class="btn-confirm">Confirmar Devolução</button>
                    </div>
                </div>

                <div class="detail-card" id="card-dragonball">
                    <div class="detail-cover cover--f"><span class="letter">悟</span></div>
                    <div class="detail-info">
                        <span class="badge-genre">Empréstimo #0228</span>
                        <h1>Dragon Ball Z</h1>
                        <p class="author">Akira Toriyama · Leitor: Elizeu</p>
                        <div class="loan-dates">
                            <div class="date-item"><span class="date-label">Retirado em</span><span class="date-value">08/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Prazo</span><span class="date-value">22/07/2026</span></div>
                            <div class="date-item"><span class="date-label">Hoje</span><span class="date-value">21/07/2026</span></div>
                        </div>
                        <div class="detail-meta"><span class="ok">No prazo · 1 dia restante</span></div>
                        <button type="button" class="btn-confirm">Confirmar Devolução</button>
                    </div>
                </div>

            </div>

        </div>

    </main>

</body>
</html>

<style>

    :root {
        --azul: #2E6FE0;
        --azul-escuro: #1B3A6B;
        --fundo: #0B0F18;
        --card-texto: #F5F8FF;
        --cinza: rgba(255,255,255,0.45);
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        background: var(--fundo);
        color: var(--card-texto);
        font-family: Arial, Helvetica, sans-serif;
    }

    .topbar {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 22px 24px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .back-link {
        color: var(--cinza);
        font-size: 0.85rem;
        text-decoration: none;
    }

        .back-link:hover {
            color: var(--card-texto);
        }

    .detail-wrapper {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 24px 60px;
    }

    .group-title {
        font-size: 1.2rem;
        font-weight: 700;
        margin: 40px 0 18px;
        padding-left: 12px;
        border-left: 4px solid var(--azul);
    }

    /* Esconde os radios de seleção */
    .book-radio {
        display: none;
    }

    /* Grade de seleção de livros (mesmo padrão da Home) */
    .grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px 16px;
        margin-bottom: 40px;
    }

    .book {
        display: flex;
        flex-direction: column;
        cursor: pointer;
        border: 2px solid transparent;
        border-radius: 8px;
        padding: 4px;
        transition: border-color .15s ease;
    }

        .book:hover .cover {
            transform: translateY(-4px);
        }

    .cover {
        position: relative;
        aspect-ratio: 3 / 4;
        border-radius: 6px;
        padding: 8px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: transform .15s ease;
    }

    .cover--a {
        background: linear-gradient(160deg, #143866, #2A5D9E);
    }

    .cover--b {
        background: linear-gradient(160deg, #0F2A4D, #1E4E8C);
    }

    .cover--c {
        background: linear-gradient(160deg, #2E5A9C, #6FA3E0);
    }

    .cover--d {
        background: linear-gradient(160deg, #1B3A6B, #4A7FC1);
    }

    .cover--e {
        background: linear-gradient(160deg, #0E1F3A, #2E5A9C);
    }

    .cover--f {
        background: linear-gradient(160deg, #163A6E, #3E71B3);
    }

    .cover--g {
        background: linear-gradient(160deg, #1A2F52, #3B6DAF);
    }

    .cover--h {
        background: linear-gradient(160deg, #0D2340, #26529A);
    }

    .letter {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3.2rem;
        font-weight: 700;
        color: rgba(255,255,255,0.28);
    }

    .book h3 {
        font-size: 0.85rem;
        margin: 10px 0 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .book .sub {
        font-size: 0.72rem;
        color: var(--cinza);
        margin: 0;
    }

    /* Destaca o livro selecionado */
    #r-capitaes:checked ~ .grid label[for="r-capitaes"],
    #r-revolucao:checked ~ .grid label[for="r-revolucao"],
    #r-domcasmurro:checked ~ .grid label[for="r-domcasmurro"],
    #r-vidassecas:checked ~ .grid label[for="r-vidassecas"],
    #r-bisquedoll:checked ~ .grid label[for="r-bisquedoll"],
    #r-apotecaria:checked ~ .grid label[for="r-apotecaria"],
    #r-tengoku:checked ~ .grid label[for="r-tengoku"],
    #r-dragonball:checked ~ .grid label[for="r-dragonball"] {
        border-color: var(--azul);
        background: rgba(46, 111, 224, 0.08);
    }

    /* Card do empréstimo — escondido até selecionar */
    .detail-card {
        display: none;
        background: #131A2A;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        padding: 28px;
        gap: 28px;
    }

    #r-capitaes:checked ~ .result #card-capitaes,
    #r-revolucao:checked ~ .result #card-revolucao,
    #r-domcasmurro:checked ~ .result #card-domcasmurro,
    #r-vidassecas:checked ~ .result #card-vidassecas,
    #r-bisquedoll:checked ~ .result #card-bisquedoll,
    #r-apotecaria:checked ~ .result #card-apotecaria,
    #r-tengoku:checked ~ .result #card-tengoku,
    #r-dragonball:checked ~ .result #card-dragonball {
        display: flex;
    }

    .detail-cover {
        width: 140px;
        aspect-ratio: 3 / 4;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .detail-cover .letter {
            font-size: 3rem;
            font-weight: 700;
            color: rgba(255,255,255,0.28);
        }

    .detail-info {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: 1;
    }

    .badge-genre {
        display: inline-block;
        background: #171F30;
        border: 1px solid rgba(255,255,255,0.1);
        color: var(--cinza);
        font-size: 0.68rem;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 999px;
        width: fit-content;
    }

    .detail-info h1 {
        font-size: 1.3rem;
        margin: 4px 0 0;
        color: var(--card-texto);
    }

    .detail-info .author {
        color: var(--cinza);
        font-size: 0.85rem;
        margin: 0 0 6px;
    }

    .loan-dates {
        display: flex;
        gap: 24px;
        margin: 6px 0;
    }

    .date-item {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .date-label {
        font-size: 0.68rem;
        color: var(--cinza);
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .date-value {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--card-texto);
    }

    .detail-meta {
        margin-top: 4px;
        padding-top: 12px;
        border-top: 1px solid rgba(255,255,255,0.08);
        font-size: 0.85rem;
    }

    .ok {
        color: #6FCF7E;
        font-weight: 600;
    }

    .late {
        color: #F0A860;
        font-weight: 600;
    }

    .btn-confirm {
        display: block;
        margin: 16px 0 0 auto;
        background: var(--azul);
        color: var(--card-texto);
        border: none;
        border-radius: 8px;
        padding: 12px 24px;
        font-size: 0.95rem;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        transition: background .15s ease;
    }

        .btn-confirm:hover {
            background: #2560C7;
        }

</style>